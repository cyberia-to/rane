 /// Build a simple dynamic matmul MIL: y = x @ W
 pub fn matmul(ic: usize, oc: usize, seq: usize) -> Source {
     let sp = seq + oc;
     let mut m = mil_header(ic, sp);
     gen_dyn_matmul(&mut m, "mm", ic, oc, seq, 0, seq, "x");
     m += &mil_footer("mm_y");
